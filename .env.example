# アプリのログインパスワード（必須）
VITE_APP_PASSWORD=your-password-here

# Google Apps Script Web App の URL（設定するとスプレッドシートをバックエンドとして使用）
# 未設定の場合は localStorage にフォールバック
# デプロイ方法: apps-script/Code.gs を Google Apps Script にコピーし、
#   「デプロイ」→「ウェブアプリ」→ 実行ユーザー:自分、アクセス:全員 でデプロイ
VITE_SHEETS_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
